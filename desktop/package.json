{
  "name": "gtt-screen-recorder",
  "version": "1.0.0",
  "description": "GlobalTechTools Desktop Screen Recorder — full system audio, mic mixing, MP4 export",
  "main": "electron.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev": "cross-env NODE_ENV=development electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "pack": "npm run build:renderer && electron-builder --dir"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.12"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "fix-webm-duration": "^1.0.6",
    "fluent-ffmpeg": "^2.1.3"
  },
  "build": {
    "appId": "com.globaltechtool.recorder",
    "productName": "GTT Screen Recorder",
    "copyright": "Copyright © 2025 GlobalTechTools",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "electron.js",
      "preload.js",
      "dist/**/*"
    ],
    "asarUnpack": [
      "**/ffmpeg-static/**",
      "**/node_modules/fluent-ffmpeg/**"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "icon": "assets/icon.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
